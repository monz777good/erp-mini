generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SALES
  ADMIN
}

enum OrderStatus {
  REQUESTED
  APPROVED
  REJECTED
  DONE
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  role      Role     @default(SALES)
  pin       String?
  createdAt DateTime @default(now())

  orders    Order[]
}

model Item {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  // 재고관리용
  bundleV   Int      @default(0)
  stockV    Int      @default(0)
  extraV    Int      @default(0)

  orders    Order[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  owner     String?
  bizNo     String?
  ykiho     String?
  addr      String?
  phone     String?
  mobile    String?
  note      String?
  createdAt DateTime @default(now())

  // ✅ 사업자등록증 “DB 저장” (Railway에서도 안전)
  // - 파일을 base64(data)로 저장. (큰 파일은 5MB 이하 권장)
  bizFileName String?
  bizFileMime String?
  bizFileData String?   @db.Text

  orders    Order[]
}

model Order {
  id           String      @id @default(cuid())
  status       OrderStatus @default(REQUESTED)
  quantity     Int         @default(1)
  createdAt    DateTime    @default(now())

  receiverName String
  receiverAddr String
  phone        String?
  mobile       String?
  note         String?

  // 관계
  userId       String
  user         User        @relation(fields: [userId], references: [id])

  itemId       String
  item         Item        @relation(fields: [itemId], references: [id])

  clientId     String
  client       Client      @relation(fields: [clientId], references: [id])
}