generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SALES
  ADMIN
}

enum OrderStatus {
  REQUESTED
  APPROVED
  REJECTED
  DONE
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  role      Role     @default(SALES)
  pin       String?
  createdAt DateTime @default(now())

  orders    Order[]
  clients   Client[]
}

model Item {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  bundleV   Int      @default(0)
  stockV    Int      @default(0)
  extraV    Int      @default(0)

  orders    Order[]
}

model Client {
  id        String   @id @default(cuid())
  name      String

  // ✅ 거래처 주소(별도)
  address   String?

  // ✅ 대표자
  ownerName String?

  // ✅ 요양기관번호 / 사업자등록번호
  careInstitutionNo String?
  bizRegNo          String?

  // ✅ 주문 자동채움용 배송 기본값
  receiverName String?
  receiverAddr String?

  // ✅ 연락처(거래처 기본 연락처)
  receiverTel    String?
  receiverMobile String?

  // (구형/호환용으로 남겨둠)
  memo      String?
  updatedAt DateTime?

  // ✅ 사업자등록증 파일 메타
  bizFileUrl        String?
  bizFileName       String?
  bizFileUploadedAt DateTime?

  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders    Order[]

  @@index([userId])
  @@index([name])
}

model Order {
  id        String      @id @default(cuid())
  status    OrderStatus @default(REQUESTED)
  quantity  Int
  createdAt DateTime    @default(now())

  receiverName String
  receiverAddr String
  phone       String?
  mobile      String?
  note        String?

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  itemId   String
  item     Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([clientId])
  @@index([itemId])
  @@index([createdAt])
}