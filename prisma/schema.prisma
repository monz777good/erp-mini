generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SALES
  ADMIN
}

enum OrderStatus {
  REQUESTED
  APPROVED
  REJECTED
  DONE
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  role      Role     @default(SALES)
  pin       String?
  createdAt DateTime @default(now())

  orders    Order[]
  clients   Client[]
}

model Item {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  // ✅ 추가
  price     Int      @default(0)

  bundleV   Int      @default(0)
  stockV    Int      @default(0)
  extraV    Int      @default(0)

  orders    Order[]
}

model Client {
  id        String   @id @default(cuid())
  name      String

  address   String?
  ownerName String?

  careInstitutionNo String?
  bizRegNo          String?

  receiverName String?
  receiverAddr String?

  receiverTel    String?
  receiverMobile String?

  memo      String?
  updatedAt DateTime?

  bizFileUrl        String?
  bizFileName       String?
  bizFileUploadedAt DateTime?

  // ✅ 이번에 추가하는 것
  email String?

  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders    Order[]

  @@index([userId])
  @@index([name])
}

model Order {
  id        String      @id @default(cuid())
  status    OrderStatus @default(REQUESTED)
  quantity  Int
  createdAt DateTime    @default(now())

  receiverName String
  receiverAddr String
  phone       String?
  mobile      String?
  note        String?

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  itemId   String
  item     Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([clientId])
  @@index([itemId])
  @@index([createdAt])
}

model EcountClient {
  id                String   @id @default(cuid())
  name              String
  bizRegNo          String?
  careInstitutionNo String?
  address           String?
  phone             String?
  mobile            String?
  ownerName         String?
  note              String?
  createdAt         DateTime @default(now())

  @@index([name])
}